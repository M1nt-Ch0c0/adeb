#!/bin/sh

if [ "$1x" == "--debugx" ]; then
	set -x
fi

umount_all() {
	# Sort by longest path first so nested submounts (from recursive binds)
	# are unmounted before their parents. Use lazy umount so a still-busy
	# parent still detaches instead of blocking teardown.
	mpoints=$(mount|cut -d ' ' -f3|grep debian|awk '{ print length, $0 }'|sort -rn|cut -d ' ' -f2-)
	for m in $mpoints;
		do umount -l $m 2>&1 > /dev/null
	done
}

for i in $(seq 0 6); do
	umount_all 2>&1 > /dev/null
done
